# Copy to .env.local for local dev; set the same key in repo secrets +
# wire it into the deploy workflow for production builds.
#
# Public OAuth client ID for the Google Identity Services Web flow. Used
# only for the Google Drive backup destination. If unset, the Drive option
# is hidden in the app and the local-file destinations work normally.
#
# See docs/google-drive-setup.md for the Cloud Console walkthrough.
VITE_GOOGLE_OAUTH_CLIENT_ID=
